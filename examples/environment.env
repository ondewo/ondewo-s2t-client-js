# ONDEWO S2T JS client -- example configuration (template, NO real secrets).
# Loaded by every example via dotenv (path resolved relative to the script).
# Copy real values in locally; keep this committed file free of secrets.

# --- Connection -------------------------------------------------------------
# Host and port of the S2T gRPC-web (Envoy) endpoint the client connects to.
ONDEWO_HOST=localhost
ONDEWO_PORT=443

# --- Secure channel ---------------------------------------------------------
# true  -> the gRPC-web endpoint is reached over https://
# false -> plain http:// (local/dev only).
ONDEWO_USE_SECURE_CHANNEL=true

# --- Keycloak (D18 bearer-token auth) --------------------------------------
# Base URL of the Keycloak server (a trailing slash / baked-in /auth is tolerated).
KEYCLOAK_URL=https://localhost/auth
# Realm whose openid-connect token endpoint is targeted.
KEYCLOAK_REALM=ondewo-ccai-platform
# PUBLIC SDK client id (no client_secret is sent for the public client).
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
# Resource-owner (ROPC) credentials used for the password grant. Leave blank here.
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# TLS certificate verification for the Keycloak token call.
# Set false only for a self-signed local Envoy.
KEYCLOAK_VERIFY_SSL=true

# --- S2T service-specific ---------------------------------------------------
# Optional comma-separated ISO language codes to filter listed pipelines by
# (e.g. "de,en"). Leave blank for no language filter.
ONDEWO_S2T_LANGUAGES=
